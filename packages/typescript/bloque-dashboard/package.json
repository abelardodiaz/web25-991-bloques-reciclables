{
  "name": "@bloque/dashboard",
  "version": "0.1.0",
  "description": "React dashboard layout components - sidebar, header, data tables, navigation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@bloque/ui": "workspace:*",
    "@bloque/types": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "@bloque/auth-react": "^0.1.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "@bloque/auth-react": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bloque/auth-react": "workspace:*",
    "@bloque/api-client": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "bloque",
    "dashboard",
    "react",
    "components",
    "layout",
    "sidebar"
