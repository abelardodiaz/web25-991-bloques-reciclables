# bloque-docker-prod environment template
# Copy to .env and CHANGE ALL passwords before deploying

# PostgreSQL
POSTGRES_USER=bloques
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bloques_prod

# Redis
REDIS_PASSWORD=CHANGE_ME

# App
APP_WORKERS=4
APP_PORT=8000

# Connection URLs (used by the app container)
DATABASE_URL=postgresql+asyncpg://bloques:CHANGE_ME@postgres:5432/bloques_prod
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ChromaDB (only needed with --profile ai)
CHROMADB_URL=http://chromadb:8000

# SSL (uncomment and set paths when enabling HTTPS)
# SSL_CERTIFICATE=/etc/nginx/ssl/cert.pem
# SSL_CERTIFICATE_KEY=/etc/nginx/ssl/key.pem
